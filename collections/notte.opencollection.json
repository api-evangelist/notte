            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.notte.cc/vaults/create",
            "body": {
              "type": "json",
              "data": "{\"name\": \"<string>\"}"
            }
          },
          "docs": "Vault Create"
        },
        {
          "info": {
            "name": "List Vaults",
